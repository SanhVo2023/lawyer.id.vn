# Database — lawyer.id.vn on Authority project (Seoul)
# Supabase Ref: vvzpvkjlkmjjnhapsrxq
# Table Prefix: lid_  (set in payload.config.ts → postgresAdapter → tablePrefix)
# See: ../../shared-assets/SUPABASE_CONFIG.md and PAYLOAD_SETUP_SPEC.md
# Password lives in PM_CREDENTIALS.md at workspace root (not in git).
#
# Session Pooler — IPv4, supports prepared statements, handles BOTH runtime and `npx payload migrate`.
DATABASE_URI=postgresql://postgres.vvzpvkjlkmjjnhapsrxq:[PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# PayloadCMS secret — generate a random 32+ character string. NEVER 'default-secret-change-me'.
PAYLOAD_SECRET=your-secret-here

# Public site URL — change to https://lawyer.id.vn when deploying
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Supabase client keys (for client-side SDK if needed)
NEXT_PUBLIC_SUPABASE_URL=https://vvzpvkjlkmjjnhapsrxq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard
